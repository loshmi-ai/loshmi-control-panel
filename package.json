{
  "name": "loshmi-control-panel",
  "module": "index.ts",
  "type": "module",
  "private": true,
  "scripts": {
    "dev": "doppler run -- bunx vite dev",
    "build": "bunx vite build",
    "kill:tcp:5173": "lsof -ti tcp:5173 | xargs kill",
    "__db__": "------------------------------",
    "db:master-d1:migrations:generate": "bun drizzle-kit generate --config src/db/drizzle.master-d1.config.ts",
    "__infra__": "---------------------------",
    "prd:pulumi:preview": "doppler run -c prd -- pulumi preview --cwd src/infra --stack loshmi-control-panel/prd",
    "prd:pulumi:refresh": "doppler run -c prd -- pulumi refresh --cwd src/infra --stack loshmi-control-panel/prd",
    "prd:pulumi:up": "doppler run -c prd -- pulumi up --cwd src/infra --stack loshmi-control-panel/prd",
    "prd:pulumi:stack-output": "doppler run -c prd -- pulumi stack output --json --cwd src/infra --stack loshmi-control-panel/prd",
    "prd:once:set-d1-database-ids": "doppler run -c prd -- bun run src/infra/tasks/set-d1-database-ids.ts"
  },
  "devDependencies": {
    "@cloudflare/vite-plugin": "^1.43.2",
    "@cloudflare/workers-types": "^5.20260707.1",
    "@react-router/dev": "8.1.0",
    "@tailwindcss/vite": "^4.3.2",
    "@trivago/prettier-plugin-sort-imports": "^6.0.2",
    "@types/bun": "^1.3.14",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@typescript-eslint/eslint-plugin": "^8.63.0",
    "@typescript-eslint/parser": "^8.63.0",
    "drizzle-kit": "^0.31.10",
    "eslint": "^10.6.0",
    "tailwindcss": "^4.3.2",
    "vite": "^8.1.3",
    "wrangler": "^4.107.0"
  },
  "peerDependencies": {
    "typescript": "^6.0.3"
  },
  "dependencies": {
    "@logtape/logtape": "^2.2.4",
    "@pulumi/cloudflare": "^6.6.0",
    "@pulumi/pulumi": "^3.146.0",
    "@react-router/node": "8.1.0",
    "@react-router/serve": "8.1.0",
    "drizzle-orm": "^0.45.2",
    "hono": "^4.12.28",
    "isbot": "5",
    "jsonc-parser": "^3.3.1",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "react-router": "8.1.0"
  }
}
